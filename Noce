-- Script de Notas de Advertencia (Warning Notes)
-- Si fallas esta nota, pierdes mucha vida

function onCreate()
    -- Precarga el sonido de error para que no haya lag
    precacheSound('missNote')
end

function opponentNoteHit(id, direction, noteType, isSustainNote)
    -- El oponente hace que la cámara tiemble un poco al cantar
    if difficulty == 2 then -- Solo en dificultad Hard
        triggerEvent('Screen Shake', '0.1, 0.005', '0.1, 0.005')
    end
end

function noteMiss(id, direction, noteType, isSustainNote)
    -- Si el jugador falla una nota normal, pero es una nota especial (opcional)
    -- O simplemente para hacer el juego más castigador:
    if getProperty('health') > 0.3 then
        setProperty('health', getHealth() - 0.05)
    end
end

function onUpdatePost(elapsed)
    -- Efecto visual: Hace que las flechas de BF brillen cuando tienes poca vida
    if getHealth() < 0.5 then
        for i = 4, 7 do
            setPropertyFromGroup('strumLineNotes', i, 'alpha', 0.7 + math.sin(getSongPosition() / 100) * 0.3)
        end
    else
        for i = 4, 7 do
            setPropertyFromGroup('strumLineNotes', i, 'alpha', 1)
        end
    end
end

-- Evento de flash al ritmo de la música (cada 4 beats)
function onBeatHit()
    if curBeat % 4 == 0 then
        triggerEvent('Add Camera Zoom', 0.03, 0.03)
    end
end
